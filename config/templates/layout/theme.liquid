<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ page_title }} - The Nordalpha</title>
  {{ content_for_header }}

  <style>
    body {
      background-color: #0b0f0d;
      color: #e2e8f0;
      font-family: sans-serif;
      margin: 0;
      padding: 0;
      text-align: center;
    }
    header {
      background-color: #141d1a;
      padding: 30px;
      border-bottom: 1px solid #24332f;
    }
    header h1 {
      margin: 0;
      letter-spacing: 2px;
      color: #e2e8f0;
    }
    .welcome-box {
      padding: 60px 20px;
    }
    .btn {
      display: inline-block;
      background-color: #4ade80;
      color: #0b0f0d;
      padding: 12px 30px;
      text-decoration: none;
      font-weight: bold;
      border-radius: 4px;
      text-transform: uppercase;
      margin-top: 20px;
    }
  </style>
</head>
<body>

  <header>
    <h1>THE NORDALPHA</h1>
  </header>

  <main role="main">
    <div class="welcome-box">
      <h2>Collection Forêt Sombre</h2>
      <p style="color: #a0aec0;">Inspiré des bois denses et des nuits nordiques.</p>
      {{ content_for_layout }}
      <a href="/collections/all" class="btn">Découvrir la boutique</a>
    </div>
  </main>

  <footer style="margin-top: 40px; color: #718096; font-size: 14px;">
    <p>&copy; 2026 The Nordalpha.</p>
  </footer>

</body>
</html>
